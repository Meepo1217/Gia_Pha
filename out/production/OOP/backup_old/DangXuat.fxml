<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<!--
    DangXuat.fxml - Màn hình Tài khoản & Đăng xuất
    Chỉ UI — backend sẽ được kết nối sau
    Controller: controller.DangXuatController
-->
<HBox xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.DangXuatController"
    stylesheets="@style.css"
    styleClass="khung-chinh"
    minWidth="750" minHeight="500">

    <!-- ==================== CỘT TRÁI ==================== -->
    <VBox styleClass="cot-trai" alignment="CENTER"
        minWidth="300" prefWidth="360" maxWidth="420">

        <!-- Tiêu đề -->
        <Label text="Sơ Đồ Gia Phả" styleClass="tieu-de-lon" />

        <Region prefHeight="20" />

        <!-- Khung avatar người dùng -->
        <VBox alignment="CENTER" styleClass="khung-nguoi-tao">

            <Label text="TÀI KHOẢN" styleClass="nhan-nguoi-tao" />
            <Region prefHeight="12" />

            <!-- Avatar tròn -->
            <StackPane styleClass="khung-anh">
                <ImageView fx:id="anhDaiDien"
                    fitWidth="130" fitHeight="130"
                    preserveRatio="true"
                    styleClass="anh-tron" />
                <Circle fx:id="vienAnh" radius="65"
                    styleClass="vien-anh-tron" />
            </StackPane>

            <Region prefHeight="14" />

            <!-- Tên người dùng (lấy từ session) -->
            <Label fx:id="tenNguoiDung"
                text="Nguyễn Văn A"
                styleClass="ten-nguoi-tao" />

            <!-- Số điện thoại -->
            <Label fx:id="soDienThoaiHienThi"
                text="📞  0912 345 678"
                styleClass="sdt-hien-thi" />

            <!-- Trạng thái tài khoản -->
            <HBox alignment="CENTER" spacing="6">
                <Circle radius="5" styleClass="dot-hoat-dong" />
                <Label text="Hoạt động" styleClass="trang-thai-hien-thi" />
            </HBox>
        </VBox>

        <Region prefHeight="24" />

        <!-- Thống kê nhanh -->
        <HBox alignment="CENTER" spacing="24" styleClass="khung-thong-ke">

            <VBox alignment="CENTER" styleClass="o-thong-ke">
                <Label fx:id="soSoDo" text="0" styleClass="so-thong-ke" />
                <Label text="Sơ đồ" styleClass="nhan-thong-ke" />
            </VBox>

            <Separator orientation="VERTICAL" styleClass="ngan-cach" />

            <VBox alignment="CENTER" styleClass="o-thong-ke">
                <Label fx:id="soThanhVien" text="0" styleClass="so-thong-ke" />
                <Label text="Thành viên" styleClass="nhan-thong-ke" />
            </VBox>

            <Separator orientation="VERTICAL" styleClass="ngan-cach" />

            <VBox alignment="CENTER" styleClass="o-thong-ke">
                <Label fx:id="soNgayDung" text="0" styleClass="so-thong-ke" />
                <Label text="Ngày dùng" styleClass="nhan-thong-ke" />
            </VBox>
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Trích dẫn -->
        <Label text="&quot;Di sản của bạn, tương lai của họ&quot;"
            styleClass="chan-trang-trai" wrapText="true" textAlignment="CENTER" />
        <Region prefHeight="16" />
    </VBox>

    <!-- ==================== CỘT PHẢI ==================== -->
    <VBox styleClass="cot-phai" alignment="TOP_CENTER"
        HBox.hgrow="ALWAYS">

        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-trong-suot"
            VBox.vgrow="ALWAYS">
            <StackPane alignment="TOP_CENTER">
                <VBox styleClass="noi-dung-phai" spacing="0" maxWidth="600">

                    <Region prefHeight="40" />

                    <!-- Tiêu đề -->
                    <Label text="Thông tin tài khoản" styleClass="tieu-de-form" />
                    <Label text="Quản lý thông tin cá nhân và phiên làm việc của bạn."
                        styleClass="mo-ta-form" wrapText="true" />

                    <Region prefHeight="28" />

                    <!-- ===== THÔNG TIN CÁ NHÂN ===== -->
                    <VBox styleClass="the-thong-tin" spacing="0">

                        <Label text="THÔNG TIN CÁ NHÂN" styleClass="tieu-de-the" />
                        <Region prefHeight="16" />

                        <!-- Họ tên -->
                        <Label text="Họ và tên" styleClass="nhan-input" />
                        <Region prefHeight="6" />
                        <HBox styleClass="khung-input-readonly" alignment="CENTER_LEFT">
                            <Label text="👤" styleClass="icon-input" />
                            <Label fx:id="hienHoTen" text="Nguyễn Văn A"
                                styleClass="gia-tri-readonly" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <Region prefHeight="16" />

                        <!-- Số điện thoại -->
                        <Label text="Số điện thoại" styleClass="nhan-input" />
                        <Region prefHeight="6" />
                        <HBox styleClass="khung-input-readonly" alignment="CENTER_LEFT">
                            <Label text="📞" styleClass="icon-input" />
                            <Label fx:id="hienSoDienThoai" text="0912 345 678"
                                styleClass="gia-tri-readonly" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <Region prefHeight="16" />

                        <!-- Email -->
                        <Label text="Email" styleClass="nhan-input" />
                        <Region prefHeight="6" />
                        <HBox styleClass="khung-input-readonly" alignment="CENTER_LEFT">
                            <Label text="📧" styleClass="icon-input" />
                            <Label fx:id="hienEmail" text="(Chưa cập nhật)"
                                styleClass="gia-tri-readonly gia-tri-trong" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <Region prefHeight="16" />

                        <!-- Ngôn ngữ -->
                        <Label text="Ngôn ngữ giao diện" styleClass="nhan-input" />
                        <Region prefHeight="6" />
                        <HBox styleClass="khung-input-readonly" alignment="CENTER_LEFT">
                            <Label text="🌐" styleClass="icon-input" />
                            <Label fx:id="hienNgonNgu" text="Tiếng Việt"
                                styleClass="gia-tri-readonly" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <Region prefHeight="16" />

                    <!-- ===== PHIÊN LÀM VIỆC ===== -->
                    <VBox styleClass="the-thong-tin" spacing="0">

                        <Label text="PHIÊN LÀM VIỆC" styleClass="tieu-de-the" />
                        <Region prefHeight="16" />

                        <!-- Thời gian đăng nhập -->
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="hang-phien">
                            <Label text="🕐" styleClass="icon-phien" />
                            <VBox>
                                <Label text="Thời gian đăng nhập" styleClass="ten-phien" />
                                <Label fx:id="thoiGianDangNhap" text="22/06/2026 - 16:53"
                                    styleClass="gia-tri-phien" />
                            </VBox>
                        </HBox>

                        <Region prefHeight="10" />
                        <Separator styleClass="duong-ngang" />
                        <Region prefHeight="10" />

                        <!-- Thiết bị -->
                        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="hang-phien">
                            <Label text="💻" styleClass="icon-phien" />
                            <VBox>
                                <Label text="Thiết bị" styleClass="ten-phien" />
                                <Label text="Windows — IntelliJ IDEA" styleClass="gia-tri-phien" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <Region prefHeight="24" />

                    <!-- ===== NÚT HÀNH ĐỘNG ===== -->

                    <!-- Nút Chỉnh sửa thông tin (TODO) -->
                    <Button text="✏️   Chỉnh sửa thông tin"
                        styleClass="nut-chinh-sua"
                        maxWidth="Infinity"
                        onAction="#xuLyChinhSua" />

                    <Region prefHeight="12" />

                    <!-- Nút Đổi mật khẩu (TODO) -->
                    <Button text="🔑   Đổi mật khẩu"
                        styleClass="nut-doi-mat-khau"
                        maxWidth="Infinity"
                        onAction="#xuLyDoiMatKhau" />

                    <Region prefHeight="24" />

                    <!-- Đường kẻ -->
                    <Separator styleClass="duong-ngang" />

                    <Region prefHeight="24" />

                    <!-- NÚT ĐĂNG XUẤT (nổi bật, màu cảnh báo) -->
                    <VBox styleClass="khung-dang-xuat" spacing="8">
                        <Label text="⚠️  Kết thúc phiên làm việc"
                            styleClass="canh-bao-dang-xuat" />
                        <Label text="Sau khi đăng xuất, bạn cần đăng nhập lại để tiếp tục."
                            styleClass="mo-ta-dang-xuat" wrapText="true" />
                        <Region prefHeight="8" />
                        <Button fx:id="nutDangXuat"
                            text="ĐĂNG XUẤT"
                            styleClass="nut-dang-xuat"
                            maxWidth="Infinity"
                            onAction="#xuLyDangXuat" />
                    </VBox>

                    <Region prefHeight="32" />

                    <!-- Nút quay lại -->
                    <HBox alignment="CENTER">
                        <Button text="← Quay lại ứng dụng"
                            styleClass="lien-ket-van-ban"
                            onAction="#xuLyQuayLai" />
                    </HBox>

                    <Region prefHeight="24" />

                </VBox>
            </StackPane>
        </ScrollPane>

    </VBox>

</HBox>