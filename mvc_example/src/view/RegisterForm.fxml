<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="controller.RegisterFormController"
           styleClass="cot-phai">
           
    <!-- Hộp chứa form được căn giữa hoàn hảo dọc và ngang -->
    <VBox alignment="CENTER_LEFT" spacing="12" maxWidth="540" maxHeight="-1">
        <padding>
            <Insets top="15" left="20" right="20" bottom="15" />
        </padding>

        <VBox spacing="2">
            <Label text="Tạo tài khoản mới" styleClass="tieu-de-dang-nhap" />
            <Label text="Bắt đầu hành trình kết nối và gìn giữ nguồn cội gia đình bạn."
                   styleClass="mo-ta-dang-nhap" wrapText="true" />
        </VBox>

        <!-- HÀNG 1: HỌ TÊN + SỐ ĐIỆN THOẠI -->
        <HBox spacing="14">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Họ và tên" styleClass="nhan-input" />
                <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                    <Label text="👤" styleClass="icon-input" />
                    <TextField fx:id="truongHoTen" promptText="Nguyễn Văn A"
                               styleClass="o-nhap-lieu" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
            
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Số điện thoại" styleClass="nhan-input" />
                <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                    <Label text="📱" styleClass="icon-input" />
                    <TextField fx:id="truongSoDienThoai" promptText="0912 345 678"
                               styleClass="o-nhap-lieu" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
        </HBox>

        <!-- HÀNG 2: EMAIL -->
        <VBox spacing="4">
            <Label text="Email liên hệ (Tùy chọn)" styleClass="nhan-input" />
            <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                <Label text="📧" styleClass="icon-input" />
                <TextField fx:id="truongEmail" promptText="vidu@email.com"
                           styleClass="o-nhap-lieu" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>

        <!-- HÀNG 3: MẬT KHẨU + XÁC NHẬN MẬT KHẨU -->
        <HBox spacing="14">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Mật khẩu" styleClass="nhan-input" />
                <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                    <Label text="🔒" styleClass="icon-input" />
                    <PasswordField fx:id="truongMatKhau" promptText="Từ 6 ký tự"
                                   styleClass="o-nhap-lieu" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
            
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Xác nhận mật khẩu" styleClass="nhan-input" />
                <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                    <Label text="🔒" styleClass="icon-input" />
                    <PasswordField fx:id="truongXacNhanMatKhau" promptText="Nhập lại"
                                   styleClass="o-nhap-lieu" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>
        </HBox>

        <!-- VAI TRÒ TRONG GIA TỘC -->
        <VBox spacing="5">
            <Label text="Vai trò của bạn trong gia tộc" styleClass="nhan-input" />
            <fx:define>
                <ToggleGroup fx:id="nhomVaiTro" />
            </fx:define>

            <HBox spacing="12">
                <VBox fx:id="thongTinChuHo" styleClass="khung-vai-tro" 
                      HBox.hgrow="ALWAYS" spacing="2" prefWidth="180" onMouseClicked="#chonVaiTroChuHo">
                    <RadioButton fx:id="rdoChuHo" text="Chủ họ (Trưởng tộc)" styleClass="radio-vai-tro"
                                 toggleGroup="$nhomVaiTro" selected="true" />
                    <Label text="Quản trị cao nhất toàn bộ cây gia phả"
                           styleClass="mo-ta-vai-tro" wrapText="true" />
                </VBox>

                <VBox fx:id="thongTinChuNha" styleClass="khung-vai-tro" 
                      HBox.hgrow="ALWAYS" spacing="2" prefWidth="180" onMouseClicked="#chonVaiTroChuNha">
                    <RadioButton fx:id="rdoChuNha" text="Thành viên / Chủ nhà" styleClass="radio-vai-tro"
                                 toggleGroup="$nhomVaiTro" />
                    <Label text="Quản lý nhánh gia đình nhỏ của bạn"
                           styleClass="mo-ta-vai-tro" wrapText="true" />
                </VBox>
            </HBox>
        </VBox>

        <!-- ĐIỀU KHOẢN -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <CheckBox fx:id="hopDongY" styleClass="hop-kiem" selected="true" />
            <Label text="Tôi cam kết thông tin gia phả là xác thực &amp; tuân thủ quy định bảo mật."
                   styleClass="chu-phu" wrapText="true" HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- NÚT BẤM -->
        <Button fx:id="nutDangKy" text="TẠO SƠ ĐỒ GIA PHẢ NGAY" styleClass="nut-dang-nhap"
                maxWidth="Infinity" prefHeight="42" onAction="#xuLyDangKy" />

        <!-- ĐÃ CÓ TÀI KHOẢN -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Đã có tài khoản gia phả?" styleClass="chu-phu" />
            <Hyperlink text="Đăng nhập ngay" styleClass="lien-ket-tao" onAction="#xuLyQuayLaiDangNhap" />
        </HBox>

    </VBox>
</StackPane>
