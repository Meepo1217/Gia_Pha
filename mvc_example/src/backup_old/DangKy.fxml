<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<!--
    DangKy.fxml - Màn hình Tạo tài khoản mới
    Controller: controller.DangKyController
-->
<HBox xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controller.DangKyController"
    stylesheets="@style.css"
    styleClass="khung-chinh"
    prefWidth="850" prefHeight="640">

    <!-- ToggleGroup phải khai báo trong fx:define -->
    <fx:define>
        <ToggleGroup fx:id="nhomVaiTro" />
    </fx:define>

    <!-- ==================== CỘT TRÁI ==================== -->
    <VBox styleClass="cot-trai" alignment="CENTER" prefWidth="360">

        <Label text="Sơ Đồ Gia Phả" styleClass="tieu-de-lon" />

        <VBox alignment="CENTER" styleClass="khung-nguoi-tao">
            <Label text="SÁNG LẬP VIÊN" styleClass="nhan-nguoi-tao" />

            <StackPane styleClass="khung-anh">
                <ImageView fx:id="anhCuTo"
                    fitWidth="140" fitHeight="140"
                    preserveRatio="true"
                    styleClass="anh-dai-dien">
                    <image>
                        <Image url="@ancestor_photo.png" />
                    </image>
                </ImageView>
            </StackPane>

            <Region prefHeight="12" />
            <Label text="Cụ Nguyễn Thị Anh" styleClass="ten-nguoi-tao" />
            <Label text="&quot;Sơ đồ Gia Phả&quot;" styleClass="chuc-danh" />
        </VBox>

        <Region prefHeight="20" />

        <Label wrapText="true" textAlignment="CENTER" styleClass="trich-dan"
            text="&quot;Cây có gốc mới nở nhành xanh ngọn, nước có nguồn mới bề rộng sông sâu.&quot;" />

        <Region prefHeight="20" />
        <Label text="Di sản của bạn, tương lai của họ" styleClass="chan-trang-trai" />
    </VBox>

    <!-- ==================== CỘT PHẢI ==================== -->
    <VBox styleClass="cot-phai" alignment="TOP_CENTER"
        prefWidth="490" HBox.hgrow="ALWAYS">

        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="scroll-trong-suot"
            VBox.vgrow="ALWAYS">
            <!-- Dùng StackPane để luôn canh giữa form khi màn hình phóng to -->
            <StackPane alignment="TOP_CENTER">
                <!-- Giới hạn maxWidth để form không bị dãn ngang quá đà gây vỡ hình -->
                <VBox styleClass="noi-dung-phai" spacing="0" maxWidth="600">

                    <Region prefHeight="36" />

                    <Label text="Tạo tài khoản mới" styleClass="tieu-de-dang-nhap" />
                    <Label text="Bắt đầu hành trình tìm lại nguồn cội gia đình bạn."
                        styleClass="mo-ta-dang-nhap" wrapText="true" />

                    <Region prefHeight="24" />

                    <!-- Họ và tên -->
                    <Label text="Họ và tên" styleClass="nhan-input" />
                    <Region prefHeight="6" />
                    <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                        <Label text="👤" styleClass="icon-input" />
                        <TextField fx:id="truongHoTen"
                            promptText="Nhập họ và tên đầy đủ"
                            styleClass="o-nhap-lieu"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region prefHeight="16" />

                    <!-- Email -->
                    <Label text="Email" styleClass="nhan-input" />
                    <Region prefHeight="6" />
                    <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                        <Label text="📧" styleClass="icon-input" />
                        <TextField fx:id="truongEmail"
                            promptText="email@vi-du.com"
                            styleClass="o-nhap-lieu"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region prefHeight="16" />

                    <!-- Mật khẩu -->
                    <Label text="Mật khẩu" styleClass="nhan-input" />
                    <Region prefHeight="6" />
                    <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                        <Label text="🔒" styleClass="icon-input" />
                        <PasswordField fx:id="truongMatKhau"
                            promptText="••••••••"
                            styleClass="o-nhap-lieu"
                            HBox.hgrow="ALWAYS" />
                        <Button fx:id="nutHienMK" text="👁"
                            styleClass="nut-mat-khau-dk"
                            onAction="#xuLyHienMatKhau" />
                    </HBox>

                    <Region prefHeight="16" />

                    <!-- Xác nhận mật khẩu -->
                    <Label text="Xác nhận mật khẩu" styleClass="nhan-input" />
                    <Region prefHeight="6" />
                    <HBox styleClass="khung-input" alignment="CENTER_LEFT">
                        <Label text="🔒" styleClass="icon-input" />
                        <PasswordField fx:id="truongXacNhanMatKhau"
                            promptText="••••••••"
                            styleClass="o-nhap-lieu"
                            HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region prefHeight="20" />

                    <!-- Vai trò trong gia tộc -->
                    <Label text="Vai trò trong gia tộc" styleClass="nhan-input" />
                    <Region prefHeight="10" />

                    <!-- Chủ hộ -->
                    <VBox styleClass="khung-vai-tro khung-vai-tro-chon" spacing="4">
                        <RadioButton fx:id="rdoChuHo"
                            text="Chủ hộ"
                            styleClass="radio-vai-tro"
                            toggleGroup="$nhomVaiTro"
                            selected="true" />
                        <Label
                            text="Toàn quyền chỉnh sửa cả nhà — quản trị cao nhất toàn bộ gia phả."
                            styleClass="mo-ta-vai-tro mo-ta-chu-ho" wrapText="true" />
                    </VBox>

                    <Region prefHeight="8" />

                    <!-- Chủ nhà -->
                    <VBox styleClass="khung-vai-tro" spacing="4">
                        <RadioButton fx:id="rdoChuNha"
                            text="Chủ nhà"
                            styleClass="radio-vai-tro"
                            toggleGroup="$nhomVaiTro" />
                        <Label text="Quản lý thông tin các thành viên trong gia đình nhà."
                            styleClass="mo-ta-vai-tro" wrapText="true" />
                    </VBox>

                    <Region prefHeight="20" />

                    <!-- Checkbox điều khoản -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <CheckBox fx:id="hopDongY" styleClass="hop-kiem">
                            <HBox.margin>
                                <Insets top="2" />
                            </HBox.margin>
                        </CheckBox>
                        <Label
                            text="Tôi đồng ý với Điều khoản dịch vụ và Chính sách bảo mật của ứng dụng."
                            styleClass="chu-phu" wrapText="true" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <Region prefHeight="20" />

                    <!-- Nút ĐĂNG KÝ -->
                    <Button fx:id="nutDangKy"
                        text="ĐĂNG KÝ TÀI KHOẢN"
                        styleClass="nut-dang-nhap"
                        maxWidth="Infinity"
                        onAction="#xuLyDangKy" />

                    <Region prefHeight="16" />

                    <!-- Link quay lại -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Đã có tài khoản?" styleClass="chu-phu" />
                        <Hyperlink text="Đăng nhập ngay"
                            styleClass="lien-ket-tao"
                            onAction="#xuLyQuayLaiDangNhap" />
                    </HBox>

                    <Region prefHeight="24" />
                </VBox>
            </StackPane>
        </ScrollPane>

    </VBox>
</HBox>